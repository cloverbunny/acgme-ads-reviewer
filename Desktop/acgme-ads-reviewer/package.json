{
  "name": "acgme-ads-reviewer",
  "version": "1.0.0",
  "description": "Secure document review tool for ACGME ADS Annual Updates",
  "main": "server.js",
  "type": "module",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "test": "node --test",
    "lint": "echo 'Add eslint configuration when ready'",
    "generate-api-key": "node bin/cli.js generate-api-key",
    "create-admin": "node bin/cli.js create-admin",
    "init-db": "node bin/cli.js init-db",
    "migrate": "node bin/cli.js migrate",
    "generate-samples": "node bin/cli.js generate-samples",
    "config": "node bin/cli.js config",
    "validate-env": "node bin/cli.js validate-env",
    "cleanup": "node bin/cli.js cleanup",
    "reset": "node bin/cli.js reset",
    "cli": "node bin/cli.js help"
  },
  "keywords": [
    "acgme",
    "ads",
    "document-review",
    "medical-education"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "axios": "^1.6.0",
    "cors": "^2.8.5",
    "dotenv": "^16.3.1",
    "express": "^4.18.2",
    "jsdom": "^29.0.2",
    "multer": "^1.4.5-lts.1",
    "pdf-parse": "^2.4.5"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
